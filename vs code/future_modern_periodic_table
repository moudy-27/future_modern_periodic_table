<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Periodic Table of Elements</title>
</head>
<body>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html{
            scroll-behavior: smooth;
            scrollbar-color: #00D9FF #0A1E3F;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0A1E3F 0%, #1a3a52 50%, #0D47A1 100%);
            padding: 30px;
            min-height: 100vh;
        }
        
        .container {
            max-width: 1500px;
            margin: 0 auto;
        }
        
        h1 {
            text-align: center;
            margin-bottom: 5px;
            font-size: 2.5em;
            background: linear-gradient(90deg, #00D9FF 0%, #00FF87 50%, #FFD700 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 30px rgba(0, 217, 255, 0.3);
            font-weight: 900;
            filter: drop-shadow(0 0 25px rgba(0, 217, 255, 0.3));
        }
        
        .subtitle {
            text-align: center;
            margin-bottom: 30px;
            color: #00FF87;
            font-size: 1.1em;
            font-weight: 600;
            text-shadow: 0 2px 8px rgba(0, 255, 135, 0.2);
        }
        
        .legend {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
            padding: 25px;
            background: linear-gradient(135deg, rgba(255,255,255,0.97) 0%, rgba(225,245,254,0.97) 100%);
            border: 3px solid rgba(0, 150, 255, 0.4);
            border-radius: 15px;
            box-shadow: 0 8px 35px rgba(0, 150, 255, 0.2);
        }
        
        .legend-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            color: #333;
        }
        
        .legend-box {
            width: 35px;
            height: 25px;
            border: 3px solid #333;
            border-radius: 5px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }
        
        .table-wrapper {
            background: linear-gradient(135deg, rgba(255,255,255,0.97) 0%, rgba(225,245,254,0.97) 100%);
            padding: 30px;
            border: 3px solid rgba(0, 150, 255, 0.4);
            border-radius: 15px;
            margin-bottom: 30px;
            overflow-x: auto;
            box-shadow: 0 8px 35px rgba(0, 150, 255, 0.2);
        }
        
        .table {
            display: grid;
            grid-template-columns: repeat(18, 1fr);
            gap: 10px;
        }
        
        .element {
            aspect-ratio: 1 / 1.35;
            border: 2px solid rgba(255,255,255,0.4);
            border-radius: 8px;
            padding: 6px;
            font-size: 0.8em;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            min-height: 95px;
            font-weight: 600;
            box-shadow: 0 5px 18px rgba(0,0,0,0.25);
            color: #fff;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
        }
        
        .element:hover {
            transform: scale(1.15) translateY(-10px) rotateY(5deg);
            box-shadow: 0 15px 40px rgba(0,0,0,0.4), 0 0 40px rgba(255,215,0,0.3);
            z-index: 10;
            filter: brightness(1.25) saturate(1.3);
            border-color: rgba(255,255,255,0.8);
        }
        
        .elem-num {
            position: absolute;
            top: 4px;
            left: 5px;
            font-size: 0.85em;
            font-weight: bold;
        }
        
        .elem-group {
            position: absolute;
            top: 4px;
            right: 5px;
            font-size: 0.75em;
            opacity: 0.7;
        }
        
        .elem-sym {
            font-size: 2em;
            font-weight: 900;
            letter-spacing: 1px;
            margin: 3px 0;
        }
        
        .elem-name {
            font-size: 0.7em;
            font-weight: bold;
        }
        
        .elem-mass {
            font-size: 0.68em;
            margin-top: 2px;
        }
        
        /* Element Categories */
        .alkali { background: linear-gradient(135deg, #FF5252 0%, #FF6E40 100%); }
        .alkaline { background: linear-gradient(135deg, #FFAB40 0%, #FFC107 100%); }
        .transition { background: linear-gradient(135deg, #2979F0 0%, #1565C0 100%); }
        .post-transition { background: linear-gradient(135deg, #7986CB 0%, #5C6BC0 100%); }
        .lanthanide { background: linear-gradient(135deg, #00C853 0%, #00BCD4 100%); }
        .actinide { background: linear-gradient(135deg, #D32F2F 0%, #D81B60 100%); }
        .metalloid { background: linear-gradient(135deg, #ecec06 0%, #d4d404 100%); }
        .nonmetal { background: linear-gradient(135deg, #00E676 0%, #1DE9B6 100%); }
        .halogen { background: linear-gradient(135deg, #FFD600 0%, #FFCA28 100%); }
        .noble { background: linear-gradient(135deg, #00BCD4 0%, #00ACC1 100%); }
        .unknown { background: linear-gradient(135deg, #B0B0B0 0%, #808080 100%); }
        
        .f-section {
            margin-bottom: 30px;
        }
        
        .f-title {
            font-weight: bold;
            margin-bottom: 15px;
            color: #00BCD4;
            font-size: 1.4em;
            text-align: center;
            text-shadow: 0 0 20px rgba(0, 188, 212, 0.4);
            letter-spacing: 1px;
        }
        
        .f-row {
            display: grid;
            grid-template-columns: repeat(15, 1fr);
            gap: 10px;
            background: linear-gradient(135deg, rgba(255,255,255,0.97) 0%, rgba(225,245,254,0.97) 100%);
            padding: 20px;
            border: 3px solid rgba(0, 150, 255, 0.4);
            border-radius: 15px;
            box-shadow: 0 8px 35px rgba(0, 150, 255, 0.2);
        }
        
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.75);
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
        }
        
        .modal.active {
            display: flex;
        }
        
        .modal-content {
            background: linear-gradient(135deg, #ffffff 0%, #e8f4f8 100%);
            padding: 35px;
            border: 4px solid rgba(0, 150, 255, 0.6);
            border-radius: 18px;
            max-width: 550px;
            width: 90%;
            box-shadow: 0 20px 60px rgba(0, 100, 200, 0.5), 0 0 50px rgba(0, 200, 255, 0.3);
        }
        
        .close-btn {
            float: right;
            font-size: 2em;
            cursor: pointer;
            background: none;
            border: none;
            color: #FF5252;
            font-weight: bold;
            transition: all 0.3s;
        }
        
        .close-btn:hover {
            color: #D32F2F;
            transform: scale(1.4) rotate(90deg);
        }
        
        .modal-header {
            clear: both;
            border-bottom: 3px solid rgba(0, 150, 255, 0.3);
            padding-bottom: 15px;
            margin-bottom: 20px;
        }
        
        .modal-sym {
            font-size: 3.5em;
            font-weight: 900;
            background: linear-gradient(135deg, #0096FF 0%, #00D9FF 50%, #00FF87 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 5px;
            filter: drop-shadow(0 2px 8px rgba(0, 150, 200, 0.3));
        }
        
        .modal-name {
            font-size: 1.8em;
            font-weight: bold;
            color: #1a1a2e;
        }
        
        .modal-info {
            display: grid;
            gap: 12px;
        }
        
        .info-row {
            display: grid;
            grid-template-columns: 130px 1fr;
            gap: 20px;
            padding: 12px;
            border-bottom: 2px solid rgba(0, 150, 255, 0.25);
            border-radius: 5px;
            background: rgba(0, 150, 255, 0.08);
            transition: all 0.3s;
        }
        
        .info-row:hover {
            background: rgba(0, 150, 255, 0.15);
            border-bottom-color: rgba(0, 150, 255, 0.5);
            padding-left: 18px;
        }
        
        .info-label {
            font-weight: bold;
            color: #0075B9;
            text-transform: uppercase;
            font-size: 0.9em;
            letter-spacing: 1.5px;
        }
        
        .info-val {
            color: #1a1a2e;
            font-weight: 500;
        }
        
        .category-list {
            display: grid;
            gap: 12px;
            margin-top: 15px;
        }
        
        .category-item {
            padding: 12px 15px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            border-left: 5px solid;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .category-item:hover {
            transform: translateX(5px);
            box-shadow: 0 4px 12px rgba(0, 150, 255, 0.2);
        }
        
        .category-color-box {
            width: 30px;
            height: 30px;
            border-radius: 5px;
            flex-shrink: 0;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }
        
        .category-text {
            flex: 1;
        }
        
        .category-name {
            font-weight: bold;
            color: #1a1a2e;
            font-size: 0.95em;
        }
        
        .category-desc {
            font-size: 0.85em;
            color: #555;
            margin-top: 3px;
            line-height: 1.4;
        }
        
        @media (max-width: 1200px) {
            .table { grid-template-columns: repeat(12, 1fr); }
            .f-row { grid-template-columns: repeat(12, 1fr); }
        }
        
        @media (max-width: 768px) {
            body { padding: 15px; }
            h1 { font-size: 1.8em; }
            .table { grid-template-columns: repeat(6, 1fr); gap: 6px; }
            .f-row { grid-template-columns: repeat(6, 1fr); gap: 6px; }
            .element { min-height: 80px; font-size: 0.7em; }
            .elem-sym { font-size: 1.5em; }
        }
        
        .info-button {
            display: block;
            margin: 40px auto 20px;
            padding: 15px 40px;
            font-size: 1.1em;
            font-weight: 600;
            background: linear-gradient(135deg, #00D9FF 0%, #00FF87 100%);
            color: #0A1E3F;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 8px 20px rgba(0, 217, 255, 0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .info-button:hover {
            transform: scale(1.1) translateY(-5px);
            box-shadow: 0 15px 40px rgba(0, 217, 255, 0.5);
            filter: brightness(1.15);
        }
        
        .info-button:active {
            transform: scale(0.98);
        }
    </style>
