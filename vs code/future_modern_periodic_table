        function makeElement(e) {
            const el = document.createElement('div');
            el.className = `element ${e.t}`;
            el.style.gridColumn = e.g;
            el.style.gridRow = e.p;
            el.innerHTML = `
                <div class="elem-num">${e.n}</div>
                <div class="elem-group">${e.g}</div>
                <div class="elem-sym">${e.s}</div>
                <div class="elem-name">${e.nm}</div>
                <div class="elem-mass">${e.m}</div>
            `;
            el.onclick = () => showModal(e);
            return el;
        }
        
        function getBlock(config) {
            // Determine block based on electron configuration
            if (config.includes('6p') || config.includes('7p') || config.includes('5p') || config.includes('4p') || config.includes('3p') || config.includes('2p')) {
                return 'p-block';
            } else if (config.includes('5f') || config.includes('4f')) {
                return 'f-block';
            } else if (config.includes('5d') || config.includes('4d') || config.includes('3d') || config.includes('6d')) {
                return 'd-block';
            } else {
                return 's-block';
            }
        }
        
        function getGroupName(groupNum) {
            const groupNames = {
                1: 'Alkali metals (Group 1A)',
                2: 'Alkaline Earth metals (Group 2A)',
                3: 'Scandium group (Group 3B)',
                4: 'Titanium group (Group 4B)',
                5: 'Vanadium group (Group 5B)',
                6: 'Chromium group (Group 6B)',
                7: 'Manganese group (Group 7B)',
                8: 'Iron group (Group 8B)',
                9: 'Cobalt group (Group 8B)',
                10: 'Nickel group (Group 8B)',
                11: 'Copper group (Group 1B)',
                12: 'Zinc group (Group 2B)',
                13: 'Boron group (Group 3A)',
                14: 'Carbon group (Group 4A)',
                15: 'Nitrogen group (Group 5A)',
                16: 'Oxygen group (Group 6A)',
                17: 'Halogens (Group 7A)',
                18: 'Noble gases[inert gas] (Zero group)'
            };
            return groupNames[groupNum] || 'Group ' + groupNum;
        }
        
        function getStateOfMatter(atomicNumber, symbol, elementType) {
            // Gases at room temperature
            const gases = [1, 2, 7, 8, 9, 10, 17, 18, 36, 54, 86, 118]; // H, He, N, O, F, Ne, Cl, Ar, Kr, Xe, Rn, Og
            
            // Liquids at room temperature
            const liquids = [35, 80]; // Br (nonmetal), Hg (metal)
            
            // Metalloids (special classification)
            const metalloids = [5, 14, 32, 33, 51, 52]; // B, Si, Ge, As, Sb, Te
            
            // Determine material type
            let materialType = 'Nonmetal';
            
            if (metalloids.includes(atomicNumber)) {
                materialType = 'Metalloid';
            } else {
                const metalTypes = ['alkali', 'alkaline', 'transition', 'post-transition', 'lanthanide', 'actinide'];
                const isMetal = metalTypes.some(type => elementType.includes(type));
                materialType = isMetal ? 'Metal' : 'Nonmetal';
            }
            
            if (gases.includes(atomicNumber)) {
                return `${materialType} Gas`;
            } else if (liquids.includes(atomicNumber)) {
                return `${materialType} Liquid`;
            } else {
                return `${materialType} Solid`;
            }
        }
        
        function showModal(e) {
            document.getElementById('modalSym').textContent = e.s;
            document.getElementById('modalName').textContent = e.nm;
            const block = getBlock(e.c);
            const groupName = getGroupName(e.g);
            const stateOfMatter = getStateOfMatter(e.n, e.s, e.t);
            document.getElementById('modalInfo').innerHTML = `
                <div class="info-row"><span class="info-label">Atomic Number:</span><span class="info-val">${e.n}</span></div>
                <div class="info-row"><span class="info-label">Atomic Mass:</span><span class="info-val">${e.m}</span></div>
                <div class="info-row"><span class="info-label">State of Matter:</span><span class="info-val">${stateOfMatter}</span></div>
                <div class="info-row"><span class="info-label">Category:</span><span class="info-val">${e.t}</span></div>
                <div class="info-row"><span class="info-label">Block:</span><span class="info-val">${block}</span></div>
                <div class="info-row"><span class="info-label">Group:</span><span class="info-val">${groupName}</span></div>
                <div class="info-row"><span class="info-label">Period:</span><span class="info-val">${e.p}</span></div>
                <div class="info-row"><span class="info-label">Electron Config:</span><span class="info-val">${e.c}</span></div>
            `;
            document.getElementById('modal').classList.add('active');
        }
        
        function closeModal() {
            document.getElementById('modal').classList.remove('active');
        }
        
        function showTableInfo() {
            const totalElements = elements.length;
            const periods = 7;
            const groups = 18;
            const blocks = ['s-block', 'p-block', 'd-block', 'f-block'];
            
            document.getElementById('tableInfoContent').innerHTML = `
                <div class="info-row"><span class="info-label">Total Elements:</span><span class="info-val">${totalElements}</span></div>
                <div class="info-row"><span class="info-label">Periods (Rows):</span><span class="info-val">${periods}</span></div>
                <div class="info-row"><span class="info-label">Groups (Columns):</span><span class="info-val">${groups}</span></div>
                <div class="info-row"><span class="info-label">Orbital Blocks:</span><span class="info-val">s, p, d, f</span></div>
                <div class="info-row"><span class="info-label">Categories:</span><span class="info-val">11 categories of elements</span></div>
                <div class="info-row"><span class="info-label">Atomic Number Range:</span><span class="info-val">1 - 118</span></div>
                <div class="info-row"><span class="info-label">About:</span><span class="info-val">This is an interactive periodic table. Click on any element to see detailed information including atomic number, mass, electron configuration, period, group, and orbital block.</span></div>
            `;
            document.getElementById('infoModal').classList.add('active');
        }
        
        function closeTableInfo() {
            document.getElementById('infoModal').classList.remove('active');
        }
        
        document.getElementById('infoModal').addEventListener('click', (e) => {
            if(e.target.id === 'infoModal') closeTableInfo();
        });
        
        // Render main periodic table
        elements.filter(e => !['lanthanide','actinide'].includes(e.t)).forEach(e => {
            document.getElementById('table').appendChild(makeElement(e));
        });
        
        // Render lanthanides
        elements.filter(e => e.t === 'lanthanide').sort((a,b) => a.n - b.n).forEach((e,i) => {
            const el = makeElement(e);
            el.style.gridColumn = i + 1;
            el.style.gridRow = 'auto';
            document.getElementById('lanthanides').appendChild(el);
        });
        
        // Render actinides
        elements.filter(e => e.t === 'actinide').sort((a,b) => a.n - b.n).forEach((e,i) => {
            const el = makeElement(e);
            el.style.gridColumn = i + 1;
            el.style.gridRow = 'auto';
            document.getElementById('actinides').appendChild(el);
        });
    </script>


</div>

</body>
</html>


























































































































































